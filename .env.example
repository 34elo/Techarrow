# Compose-level overrides for `docker compose [-f docker-compose.dev.yml] up`.
# Copy to `.env` and tweak as needed.

# Base URL the browser will hit. Baked into the production bundle at build time
# (NEXT_PUBLIC_*), so rebuild images after changing it.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Host ports. Container always listens on 3000.
WEB_PORT=3000
ADMIN_PORT=3001
